{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "capstone5"
		},
		"ls_AzureDatabricks_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_AzureDatabricks'"
		},
		"ls_AzureDatabricksR_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_AzureDatabricksR'"
		},
		"ls_AzureDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://capstone05.dfs.core.windows.net"
		},
		"ls_AzureDatabricksR_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0521-091753-vk41t6si"
		},
		"ls_AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://capstone05key.vault.azure.net/"
		},
		"ls_AzureSQLDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-capstone-g3.database.windows.net"
		},
		"ls_AzureSQLDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-manufacturing-source"
		},
		"ls_AzureSQLDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "capstone5_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_AzureDatabricks_accessToken": {
						"value": "[parameters('ls_AzureDatabricks_accessToken')]"
					},
					"ls_AzureDatabricksR_accessToken": {
						"value": "[parameters('ls_AzureDatabricksR_accessToken')]"
					},
					"ls_AzureDatabricksR_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_AzureDatabricksR_properties_typeProperties_existingClusterId')]"
					},
					"ls_AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"ls_AzureDataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('ls_AzureDataLakeStorage_properties_typeProperties_url')]"
					},
					"ls_AzureSQLDatabase_properties_typeProperties_server": {
						"value": "[parameters('ls_AzureSQLDatabase_properties_typeProperties_server')]"
					},
					"ls_AzureSQLDatabase_properties_typeProperties_database": {
						"value": "[parameters('ls_AzureSQLDatabase_properties_typeProperties_database')]"
					},
					"ls_AzureSQLDatabase_properties_typeProperties_userName": {
						"value": "[parameters('ls_AzureSQLDatabase_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}